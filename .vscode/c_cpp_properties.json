{
    "version": 4,
    "configurations": [
        {
            "name": "Civitas-X",
            "includePath": [
                "${workspaceFolder}/include",
                "${workspaceFolder}/src",
                "${workspaceFolder}/build-nmake/vcpkg_installed/x64-windows/include",
                "${workspaceFolder}/build/vcpkg_installed/x64-windows/include",
                "${workspaceFolder}/build-clean/vcpkg_installed/x64-windows/include",
                "${env:USERPROFILE}/vcpkg/installed/x64-windows/include",
                "${env:VCPKG_ROOT}/installed/x64-windows/include",
                "${workspaceFolder}/vcpkg_installed/x64-windows/include",
                "C:/vcpkg/installed/x64-windows/include"
            ],
            "defines": [
                "UNICODE",
                "_UNICODE"
            ],
            "cStandard": "c17",
            "cppStandard": "c++20",
            "intelliSenseMode": "windows-msvc-x64"
        }
    ]
}